# Backend config
PORT=9009
DB_PATH=pager.db

# Security
APP_SECRET=change-me-to-random-64-char-hex
MESH_SECRET=shared-secret-between-mesh-nodes
CORS_ORIGINS=https://your-domain.example

# MongoDB (optional)
MONGODB_URI=mongodb://localhost:27017/mesh_pager

# Ephemeral messages: default TTL in seconds (86400 = 24h, 0 = no expiry)
MESSAGE_TTL_DEFAULT=86400

# Mesh Network
NODE_ID=node-alpha
MESH_PEERS=["http://10.0.0.2:9009","http://10.0.0.3:9009"]
